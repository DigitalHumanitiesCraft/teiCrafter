.claude/settings.local.json
.vscode/settings.json
output/
__pycache__/
*.pyc
*.stackdump

# Example data under docs/data/editor/: the payload stays local-only by default,
# only the project manifest, README and NOTICE are tracked. Named exceptions
# below re-include fully redistributable material. Local-only payloads are
# regenerated via test/tools/make_*.mjs or copied from their source repos.
docs/data/editor/*/*
!docs/data/editor/*/teicrafter.project.json
!docs/data/editor/*/README.md
!docs/data/editor/*/NOTICE.md

# hsa-7711: the 1879 letter text (public domain) and its mapping are tracked;
# the edition's editorial apparatus (target-reference.xml) stays local-only.
!docs/data/editor/hsa-7711/brief-benndorf-1879.txt
!docs/data/editor/hsa-7711/mapping.md

# szd: CC BY object (see its NOTICE.md), fully tracked.
!docs/data/editor/szd/*
